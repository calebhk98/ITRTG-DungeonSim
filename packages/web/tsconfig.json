{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Override lib to include DOM APIs needed for React
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // React JSX transform
    "jsx": "react-jsx",
    // Include vitest/globals types so describe/it/expect are recognized
    "types": ["vitest/globals"],
    "paths": {
      "@itrtg-sim/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
